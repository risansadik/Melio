// Prisma schema for the Interactive Recipe Application
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  savedRecipes  SavedRecipe[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// Server-side record of issued refresh tokens, so they can be looked up,
// rotated, and revoked (logout / logout-all-devices) instead of trusting
// the JWT alone.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// A user's saved/favorited recipe. We cache the minimal display fields
// (title, image) returned by Spoonacular so the "My Saved Recipes" list
// can render without an extra API call per item; full details are still
// fetched live from Spoonacular by spoonacularId when the user opens it.
model SavedRecipe {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spoonacularId   Int
  title           String
  image           String?
  createdAt       DateTime @default(now())

  @@unique([userId, spoonacularId])
  @@index([userId])
  @@map("saved_recipes")
}
